<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.local.flightdeck</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ben/Library/CloudStorage/OneDrive-Personal/Projects/GitHub/FlightDeck/flightdeck-start.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
      <key>FLIGHTDECK_NO_BROWSER</key>
      <string>1</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/flightdeck.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/flightdeck-error.log</string>
  </dict>
</plist>
