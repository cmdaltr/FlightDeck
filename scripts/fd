#!/usr/bin/env bash
# fd — FlightDeck CLI
# Usage:
#   fd status               show all apps
#   fd start <id>|--all     start one or all apps
#   fd stop  <id>|--all     stop one or all apps
#   fd restart <id>         stop then start one app
#   fd open <id>            open app in browser

set -euo pipefail

API="${FLIGHTDECK_API:-http://localhost:5050}"

# Resolve symlinks to find the repo root (handles /usr/local/bin/fd → scripts/fd)
_fd_real="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
[[ "${_fd_real}" != /* ]] && _fd_real="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/${_fd_real}"
FD_ROOT="$(cd "$(dirname "${_fd_real}")/.." && pwd)"
PLIST_SRC="${FD_ROOT}/config/com.flightdeck.plist"
PLIST_DST="${HOME}/Library/LaunchAgents/com.flightdeck.plist"

# ── Colours ──────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; PALEGREEN='\033[2;32m'
CYAN='\033[0;36m';  DIM='\033[2m';    BOLD='\033[1m';  RESET='\033[0m'

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${CYAN}»${RESET} $*"; }

# ── Require curl & jq ────────────────────────────────────────────────────────
command -v curl >/dev/null || die "curl is required"
command -v jq   >/dev/null || die "jq is required"

api() {
    local method="$1" path="$2"
    curl -sf -X "$method" "${API}${path}" \
         -H 'Content-Type: application/json' \
         "${@:3}" \
    || die "Could not reach FlightDeck at ${API} — is it running?"
}

# ── status ───────────────────────────────────────────────────────────────────
cmd_status() {
    # FlightDeck own status
    local be_pid hp_pid
    be_pid=$(lsof -ti :5050 2>/dev/null || true)
    hp_pid=$(lsof -ti :3325 2>/dev/null || true)
    echo ""
    if [[ -n "$be_pid" && -n "$hp_pid" ]]; then
        echo -e "  ${GREEN}●${RESET}  FlightDeck        ${GREEN}running${RESET}  backend PID ${be_pid}  homepage PID ${hp_pid}"
    elif [[ -n "$be_pid" ]]; then
        echo -e "  ${YELLOW}●${RESET}  FlightDeck        ${YELLOW}partial${RESET}  backend PID ${be_pid}  homepage ${RED}not running${RESET}"
    elif [[ -n "$hp_pid" ]]; then
        echo -e "  ${YELLOW}●${RESET}  FlightDeck        ${YELLOW}partial${RESET}  backend ${RED}not running${RESET}  homepage PID ${hp_pid}"
    else
        echo -e "  ${RED}●${RESET}  FlightDeck        ${RED}stopped${RESET}"
    fi
    echo ""

    local apps
    apps=$(api GET /api/apps)

    printf "${BOLD}%-22s %-10s %-8s %-8s %-8s %s${RESET}\n" \
        "APP" "TYPE" "PORT" "RUNNING" "HEALTHY" "URL"
    printf '%s\n' "$(printf '─%.0s' {1..72})"

    echo "$apps" | jq -r '.[] | [.id, .launch_type, (.port|tostring),
        (.running|if . then "yes" else "no" end),
        (if .health_endpoint == null then "—" elif .healthy then "yes" else "no" end),
        (.web_url // .url)] | @tsv' \
    | while IFS=$'\t' read -r id type port running healthy url; do
        if   [[ "$running" == "yes" && "$healthy" == "yes" ]]; then
            col="${GREEN}"
        elif [[ "$running" == "yes" && "$healthy" == "no" ]]; then
            col="${RED}"
        elif [[ "$running" == "yes" ]]; then
            col="${PALEGREEN}"
        else
            col="${DIM}"
        fi
        printf "${col}%-22s %-10s %-8s %-8s %-8s %s${RESET}\n" \
            "$id" "$type" "$port" "$running" "$healthy" "$url"
    done

    local total running_count
    total=$(echo "$apps" | jq '[.[] | select(.launch_type != "docker")] | length')
    running_count=$(echo "$apps" | jq '[.[] | select(.running == true and .launch_type != "docker")] | length')
    echo ""
    echo -e "${DIM}${running_count}/${total} managed apps running${RESET}"
}

# ── start ─────────────────────────────────────────────────────────────────────
cmd_start() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        info "Starting FlightDeck…"
        FLIGHTDECK_NO_BROWSER=1 nohup "$FD_ROOT/flightdeck-start.sh" >> /tmp/flightdeck.log 2>&1 &
        local fd_pid=$!
        echo -e "${DIM}Waiting for services to start…${RESET}"
        sleep 4
        local be_pid hp_pid
        be_pid=$(lsof -ti :5050 2>/dev/null || true)
        hp_pid=$(lsof -ti :3325 2>/dev/null || true)
        [[ -n "$be_pid" ]] && echo -e "  ${GREEN}✓${RESET}  Backend API   → http://localhost:5050  (PID ${be_pid})"  || echo -e "  ${RED}✗${RESET}  Backend API   failed to start — check /tmp/flightdeck-backend.log"
        [[ -n "$hp_pid" ]] && echo -e "  ${GREEN}✓${RESET}  Homepage      → http://localhost:3325  (PID ${hp_pid})" || echo -e "  ${RED}✗${RESET}  Homepage      failed to start — check /tmp/flightdeck-homepage.log"
        return
    fi

    if [[ "$target" == "--all" ]]; then
        info "Starting all apps…"
        local result
        result=$(api POST /api/start)
        local started skipped errors
        started=$(echo "$result" | jq -r '.started[]?' | paste -sd', ' -)
        skipped=$(echo "$result" | jq -r '.skipped[]?' | paste -sd', ' -)
        errors=$(echo "$result"  | jq -r '.errors[]?'  | paste -sd', ' -)
        [[ -n "$started" ]] && echo -e "${GREEN}started:${RESET} $started"
        [[ -n "$skipped" ]] && echo -e "${DIM}skipped: $skipped${RESET}"
        [[ -n "$errors"  ]] && echo -e "${RED}errors:  $errors${RESET}"
    else
        info "Starting ${target}…"
        local msg
        msg=$(api POST "/api/start/${target}" | jq -r '.message // .error')
        echo -e "${GREEN}${msg}${RESET}"
    fi
}

# ── stop ──────────────────────────────────────────────────────────────────────
cmd_stop() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        info "Stopping FlightDeck…"
        local killed=0
        for port in 5050 3325; do
            local pid
            pid=$(lsof -ti ":${port}" 2>/dev/null || true)
            if [[ -n "$pid" ]]; then
                kill "$pid" 2>/dev/null && echo -e "${RED}stopped port ${port} (PID ${pid})${RESET}"
                ((killed++)) || true
            fi
        done
        [[ $killed -eq 0 ]] && echo -e "${DIM}FlightDeck was not running${RESET}"
        return
    fi

    if [[ "$target" == "--all" ]]; then
        info "Stopping all apps…"
        local result
        result=$(api POST /api/stop)
        local stopped errors
        stopped=$(echo "$result" | jq -r '.stopped[]?' | paste -sd', ' -)
        errors=$(echo "$result"  | jq -r '.errors[]?'  | paste -sd', ' -)
        [[ -n "$stopped" ]] && echo -e "${RED}stopped:${RESET} $stopped"
        [[ -z "$stopped" ]] && echo -e "${DIM}nothing was running${RESET}"
        [[ -n "$errors"  ]] && echo -e "${RED}errors:  $errors${RESET}"
    else
        info "Stopping ${target}…"
        local msg
        msg=$(api POST "/api/stop/${target}" | jq -r '.message // .error')
        echo -e "${RED}${msg}${RESET}"
    fi
}

# ── restart ───────────────────────────────────────────────────────────────────
cmd_restart() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        info "Restarting FlightDeck…"
        cmd_stop
        sleep 1
        cmd_start
        return
    fi
    cmd_stop "$target"
    sleep 1
    cmd_start "$target"
}

# ── pull ──────────────────────────────────────────────────────────────────────
cmd_pull() {
    local target="${1:-}"
    [[ -z "$target" ]] && { echo "Usage: fd pull <id>|--all"; exit 1; }

    if [[ "$target" == "--all" ]]; then
        info "Pulling all repos…"
        local result
        result=$(api POST /api/repo/pull-all)
        echo "$result" | jq -r '.results[] | select(.skipped != true) |
            if .error then "  \(.app_id): ERROR \(.error)"
            else "  \(.app_id): \(.message)"
            end' \
        | while IFS= read -r line; do
            if [[ "$line" == *"ERROR"* ]]; then
                echo -e "${RED}${line}${RESET}"
            elif [[ "$line" == *"up to date"* || "$line" == *"up-to-date"* ]]; then
                echo -e "${DIM}${line}${RESET}"
            else
                echo -e "${GREEN}${line}${RESET}"
            fi
        done
        local pulled skipped errors
        pulled=$(echo "$result"  | jq -r '.pulled[]?'  | paste -sd', ' -)
        skipped=$(echo "$result" | jq -r '.skipped[]?' | paste -sd', ' -)
        errors=$(echo "$result"  | jq -r '.errors[]?'  | paste -sd', ' -)
        echo ""
        [[ -n "$pulled"  ]] && echo -e "${GREEN}pulled:${RESET}  $pulled"
        [[ -n "$skipped" ]] && echo -e "${DIM}skipped: $skipped${RESET}"
        [[ -n "$errors"  ]] && echo -e "${RED}errors:  $errors${RESET}"
    else
        info "Pulling ${target}…"
        local msg
        msg=$(api POST "/api/repo/${target}/pull" | jq -r '.message // .error')
        echo -e "${GREEN}${msg}${RESET}"
    fi
}

# ── commit ────────────────────────────────────────────────────────────────────
cmd_commit() {
    local message="" target=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -m) shift; message="$1" ;;
            *)  target="$1" ;;
        esac
        shift
    done
    [[ -z "$target" ]] && { echo "Usage: fd commit [-m \"msg\"] <id>|--all"; exit 1; }

    if [[ "$target" == "--all" && -z "$message" ]]; then
        # Interactive: unique message per repo
        info "Commit all repos — enter a message per repo, blank to skip…"
        echo ""
        local apps
        apps=$(api GET /api/apps)
        while IFS= read -r app_id; do
            printf "${BOLD}%-22s${RESET} message: " "$app_id"
            local msg
            read -r msg </dev/tty
            if [[ -z "$msg" ]]; then
                echo -e "  ${DIM}skipped${RESET}"
                continue
            fi
            local body result out
            body=$(jq -n --arg m "$msg" '{"message":$m}')
            # Use curl -s (not -f) so HTTP errors return JSON instead of exiting
            result=$(curl -s -X POST "${API}/api/repo/${app_id}/commit" \
                -H 'Content-Type: application/json' -d "$body" 2>/dev/null) \
                || result='{"error":"could not reach FlightDeck"}'
            out=$(echo "$result" | jq -r '.message // .error')
            if echo "$result" | jq -e '.error' >/dev/null 2>&1; then
                echo -e "  ${RED}${out}${RESET}"
            else
                echo -e "  ${GREEN}${out}${RESET}"
            fi
        done < <(echo "$apps" | jq -r '.[] | select(.launch_type != "docker") | .id')

    elif [[ "$target" == "--all" ]]; then
        # Batch: same message to all repos
        local body
        body=$(jq -n --arg m "$message" '{"message":$m}')
        info "Committing all repos…"
        local result
        result=$(api POST /api/repo/commit-all -d "$body")
        echo "$result" | jq -r '.results[] | select(.skipped != true) |
            if .error then "  \(.app_id): ERROR \(.error)"
            else "  \(.app_id): \(.message)"
            end' \
        | while IFS= read -r line; do
            if [[ "$line" == *"ERROR"* ]]; then echo -e "${RED}${line}${RESET}"
            else echo -e "${GREEN}${line}${RESET}"; fi
        done
        local committed skipped errors
        committed=$(echo "$result" | jq -r '.committed[]?' | paste -sd', ' -)
        skipped=$(echo "$result"   | jq -r '.skipped[]?'  | paste -sd', ' -)
        errors=$(echo "$result"    | jq -r '.errors[]?'   | paste -sd', ' -)
        echo ""
        [[ -n "$committed" ]] && echo -e "${GREEN}committed:${RESET} $committed"
        [[ -n "$skipped"   ]] && echo -e "${DIM}skipped:   $skipped${RESET}"
        [[ -n "$errors"    ]] && echo -e "${RED}errors:    $errors${RESET}"

    else
        [[ -z "$message" ]] && { echo "Usage: fd commit -m \"message\" <id>"; exit 1; }
        local body
        body=$(jq -n --arg m "$message" '{"message":$m}')
        info "Committing ${target}…"
        local out
        out=$(api POST "/api/repo/${target}/commit" -d "$body" | jq -r '.message // .error')
        echo -e "${GREEN}${out}${RESET}"
    fi
}

# ── push ──────────────────────────────────────────────────────────────────────
cmd_push() {
    local target="${1:-}"
    [[ -z "$target" ]] && { echo "Usage: fd push <id>|--all"; exit 1; }

    if [[ "$target" == "--all" ]]; then
        info "Pushing all repos…"
        local result
        result=$(api POST /api/repo/push-all)
        echo "$result" | jq -r '.results[] | select(.skipped != true) |
            if .error then "  \(.app_id): ERROR \(.error)"
            else "  \(.app_id): \(.message)"
            end' \
        | while IFS= read -r line; do
            if [[ "$line" == *"ERROR"* ]]; then echo -e "${RED}${line}${RESET}"
            else echo -e "${CYAN}${line}${RESET}"; fi
        done
        local pushed skipped errors
        pushed=$(echo "$result"  | jq -r '.pushed[]?'   | paste -sd', ' -)
        skipped=$(echo "$result" | jq -r '.skipped[]?'  | paste -sd', ' -)
        errors=$(echo "$result"  | jq -r '.errors[]?'   | paste -sd', ' -)
        echo ""
        [[ -n "$pushed"  ]] && echo -e "${CYAN}pushed:${RESET}  $pushed"
        [[ -n "$skipped" ]] && echo -e "${DIM}skipped: $skipped${RESET}"
        [[ -n "$errors"  ]] && echo -e "${RED}errors:  $errors${RESET}"
    else
        info "Pushing ${target}…"
        local msg
        msg=$(api POST "/api/repo/${target}/push" | jq -r '.message // .error')
        echo -e "${CYAN}${msg}${RESET}"
    fi
}

# ── repo ──────────────────────────────────────────────────────────────────────
cmd_repo() {
    local target="${1:-}"
    [[ -z "$target" ]] && { echo "Usage: fd repo <id>"; exit 1; }
    info "Fetching repo status for ${target}…"
    local data
    data=$(api GET "/api/repo/${target}")
    local err
    err=$(echo "$data" | jq -r '.error // empty')
    [[ -n "$err" ]] && die "$err"

    local branch remote last_commit ahead behind dirty_count
    branch=$(echo "$data"      | jq -r '.branch')
    remote=$(echo "$data"      | jq -r '.remote // "none"')
    last_commit=$(echo "$data" | jq -r '.last_commit // "none"')
    ahead=$(echo "$data"       | jq -r '.ahead')
    behind=$(echo "$data"      | jq -r '.behind')
    dirty_count=$(echo "$data" | jq -r '.dirty_count')

    echo ""
    printf "  ${BOLD}%-12s${RESET} ${GREEN}%s${RESET}\n"   "branch"      "$branch"
    printf "  ${BOLD}%-12s${RESET} ${DIM}%s${RESET}\n"     "remote"      "$remote"
    printf "  ${BOLD}%-12s${RESET} ${DIM}%s${RESET}\n"     "last commit" "$last_commit"
    [[ "$ahead"  -gt 0 ]] && printf "  ${BOLD}%-12s${RESET} ${CYAN}%s${RESET}\n" "ahead"  "${ahead} commit(s) to push"
    [[ "$behind" -gt 0 ]] && printf "  ${BOLD}%-12s${RESET} ${RED}%s${RESET}\n"  "behind" "${behind} commit(s) to pull"
    if [[ "$dirty_count" -gt 0 ]]; then
        printf "  ${BOLD}%-12s${RESET} ${RED}%s file(s)${RESET}\n" "dirty" "$dirty_count"
        echo "$data" | jq -r '.dirty_files[]?' | while IFS= read -r f; do
            echo -e "    ${DIM}${f}${RESET}"
        done
    else
        printf "  ${BOLD}%-12s${RESET} ${DIM}clean${RESET}\n" "dirty"
    fi
}

# ── hygiene ───────────────────────────────────────────────────────────────────
cmd_hygiene() {
    local target="${1:-}" action="${2:-}"
    [[ -z "$target" ]] && { echo "Usage: fd hygiene <id> [fix]"; exit 1; }

    if [[ "$action" == "fix" ]]; then
        info "Fixing hygiene issues for ${target}…"
        local result
        result=$(api POST "/api/repo/${target}/hygiene/fix")
        local err
        err=$(echo "$result" | jq -r '.error // empty')
        if [[ -n "$err" ]]; then
            echo -e "${RED}${err}${RESET}"
        else
            echo -e "${GREEN}$(echo "$result" | jq -r '.message // "Fixed."')${RESET}"
        fi
        return
    fi

    info "Running hygiene checks for ${target}…"
    local data
    data=$(api GET "/api/repo/${target}/hygiene")
    local err
    err=$(echo "$data" | jq -r '.error // empty')
    [[ -n "$err" ]] && die "$err"

    echo ""
    echo "$data" | jq -r '.checks[] | [if .passed then "pass" else "fail" end, .name, (.detail // "")] | @tsv' \
    | while IFS=$'\t' read -r status name detail; do
        if [[ "$status" == "pass" ]]; then
            echo -e "  ${GREEN}✓${RESET}  ${name}${detail:+  ${DIM}${detail}${RESET}}"
        else
            echo -e "  ${RED}✗${RESET}  ${name}${detail:+  ${DIM}${detail}${RESET}}"
        fi
    done

    local passed total fix_avail
    passed=$(echo "$data"    | jq -r '.passed')
    total=$(echo "$data"     | jq -r '.total')
    fix_avail=$(echo "$data" | jq -r '.fix_available')
    echo ""
    if [[ "$passed" -eq "$total" ]]; then
        echo -e "${GREEN}${passed}/${total} checks passed${RESET}"
    else
        echo -e "${RED}${passed}/${total} checks passed${RESET}"
        [[ "$fix_avail" == "true" ]] && echo -e "${DIM}Run 'fd hygiene ${target} fix' to auto-fix .gitignore${RESET}"
    fi
}

# ── autostart ─────────────────────────────────────────────────────────────────
cmd_autostart() {
    local target="${1:-}"
    [[ -z "$target" ]] && { echo "Usage: fd autostart <id>"; exit 1; }
    info "Toggling autostart for ${target}…"
    local result
    result=$(api POST "/api/apps/${target}/autostart")
    local err
    err=$(echo "$result" | jq -r '.error // empty')
    [[ -n "$err" ]] && die "$err"
    local val
    val=$(echo "$result" | jq -r '.autostart')
    if [[ "$val" == "true" ]]; then
        echo -e "${GREEN}autostart enabled${RESET} for ${target}"
    else
        echo -e "${DIM}autostart disabled${RESET} for ${target}"
    fi
}

# ── add ───────────────────────────────────────────────────────────────────────
cmd_add() {
    local path="" yes=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes|-y) yes=true ;;
            *) path="$1" ;;
        esac
        shift
    done
    [[ -z "$path" ]] && { echo "Usage: fd add [--yes] <path>"; exit 1; }

    # Show current registry
    info "Current apps:"
    api GET /api/apps \
        | jq -r '.[] | "  \(.id)\t\(.launch_type)\tport \(.port)\t\(.url)"' \
        | column -t
    echo ""

    info "Analyzing ${path}…"
    local body result err
    body=$(jq -n --arg p "$path" '{"path":$p}')
    result=$(api POST /api/apps/analyze -d "$body")
    err=$(echo "$result" | jq -r '.error // empty')
    [[ -n "$err" ]] && die "$err"

    echo ""
    printf "  ${BOLD}%-14s${RESET} %s\n" "id:"          "$(echo "$result" | jq -r '.id // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "name:"        "$(echo "$result" | jq -r '.name // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "launch_type:" "$(echo "$result" | jq -r '.launch_type // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "port:"        "$(echo "$result" | jq -r '.port // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "script:"      "$(echo "$result" | jq -r '.script // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "venv:"        "$(echo "$result" | jq -r '.venv // "—"')"
    printf "  ${BOLD}%-14s${RESET} %s\n" "health:"      "$(echo "$result" | jq -r '.health_endpoint // "—"')"

    local notes
    notes=$(echo "$result" | jq -r '.notes[]?' 2>/dev/null)
    if [[ -n "$notes" ]]; then
        echo ""
        echo -e "  ${DIM}Notes:${RESET}"
        while IFS= read -r note; do
            echo -e "    ${DIM}· ${note}${RESET}"
        done <<< "$notes"
    fi

    echo ""
    if ! $yes; then
        printf "Add this app? [y/N] "
        local confirm
        read -r confirm </dev/tty
        [[ "${confirm,,}" != "y" ]] && { echo "Aborted."; exit 0; }
    fi

    local add_result add_err
    add_result=$(api POST /api/apps/add -d "$result")
    add_err=$(echo "$add_result" | jq -r '.error // empty')

    # Live port conflict — offer to force
    if [[ -n "$add_err" ]] && echo "$add_result" | jq -e '.port_in_use' >/dev/null 2>&1; then
        echo -e "${YELLOW}Warning:${RESET} ${add_err}"
        local do_force=false
        if $yes; then
            do_force=true
        else
            printf "Add anyway (port conflict)? [y/N] "
            local fc
            read -r fc </dev/tty
            [[ "${fc,,}" == "y" ]] && do_force=true
        fi
        if $do_force; then
            add_result=$(api POST /api/apps/add -d "$(echo "$result" | jq '. + {"force": true}')")
            add_err=$(echo "$add_result" | jq -r '.error // empty')
        else
            echo "Aborted."; exit 0
        fi
    fi

    [[ -n "$add_err" ]] && die "$add_err"
    echo -e "${GREEN}$(echo "$add_result" | jq -r '.message')${RESET}"
}

# ── open ──────────────────────────────────────────────────────────────────────
cmd_open() {
    local target="${1:-}"
    [[ -z "$target" ]] && { echo "Usage: fd open <id>"; exit 1; }
    local url
    url=$(api GET /api/apps | jq -r --arg id "$target" '.[] | select(.id == $id) | .web_url // .url')
    [[ -z "$url" ]] && die "App '${target}' not found"
    info "Opening ${url}"
    open "$url" 2>/dev/null || xdg-open "$url" 2>/dev/null || die "Cannot open browser"
}

# ── config ────────────────────────────────────────────────────────────────────
cmd_config() {
    local key="${1:-}" value="${2:-}"

    _login_status() {
        if [[ -f "$PLIST_DST" ]]; then
            echo -e "  start-at-login   ${GREEN}enabled${RESET}"
        else
            echo -e "  start-at-login   ${DIM}disabled${RESET}"
        fi
    }

    case "$key" in
        start-at-login)
            case "${value:-status}" in
                on)
                    [[ -f "$PLIST_SRC" ]] || die "Plist not found: ${PLIST_SRC}"
                    cp "$PLIST_SRC" "$PLIST_DST"
                    launchctl load -w "$PLIST_DST" 2>/dev/null \
                        || launchctl load "$PLIST_DST"
                    echo -e "${GREEN}start-at-login enabled${RESET}"
                    echo -e "${DIM}FlightDeck will start at every login (browser suppressed).${RESET}"
                    echo -e "${DIM}Per-app autostart is controlled via 'fd autostart <id>'.${RESET}"
                    ;;
                off)
                    if [[ -f "$PLIST_DST" ]]; then
                        launchctl unload "$PLIST_DST" 2>/dev/null || true
                        rm -f "$PLIST_DST"
                        echo -e "${DIM}start-at-login disabled${RESET}"
                    else
                        echo -e "${DIM}Already disabled${RESET}"
                    fi
                    ;;
                status)
                    _login_status
                    ;;
                *) die "Usage: fd config start-at-login [on|off|status]" ;;
            esac
            ;;
        "")
            echo ""
            _login_status
            echo ""
            echo -e "${DIM}Use 'fd config <key> on|off' to change.${RESET}"
            ;;
        *) die "Unknown config key '${key}'. Run 'fd config' for options." ;;
    esac
}

# ── help ──────────────────────────────────────────────────────────────────────
cmd_help() {
    cat <<EOF
${BOLD}fd${RESET} — FlightDeck CLI

${BOLD}USAGE${RESET}
  fd status               FlightDeck status + all apps
  fd start                start FlightDeck itself
  fd start <id>           start a single app
  fd start --all          start all manageable apps
  fd stop                 stop FlightDeck itself
  fd stop  <id>           stop a single app
  fd stop  --all          stop all running apps
  fd restart              restart FlightDeck itself
  fd restart <id>         restart a single app
  fd restart <id>         stop then start an app
  fd open   <id>          open app URL in browser
  fd repo   <id>          show git repo status (branch, ahead/behind, dirty)
  fd pull   <id>          git pull one app's repo
  fd pull   --all         git pull all app repos
  fd commit --all            interactive commit — unique message per repo
  fd commit -m "msg" <id>    git add -A + commit one repo
  fd commit -m "msg" --all   git add -A + commit all repos with same message
  fd push   <id>          git push one app's repo
  fd push   --all         git push all app repos
  fd hygiene <id>         run hygiene checks for one repo
  fd hygiene <id> fix     auto-fix .gitignore issues
  fd autostart <id>       toggle autostart for one app
  fd add    <path>        analyze a directory and add it as a new app
  fd add -y <path>        add without confirmation prompt (non-interactive)
  fd reload               reload apps.json without restarting FlightDeck
  fd config               show current configuration
  fd config start-at-login on|off   install/remove login launch agent

${BOLD}ENV${RESET}
  FLIGHTDECK_API          API base URL (default: http://localhost:5050)
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────
CMD="${1:-status}"
shift || true

case "$CMD" in
    status)  cmd_status ;;
    start)   cmd_start  "$@" ;;
    stop)    cmd_stop   "$@" ;;
    restart) cmd_restart "$@" ;;
    open)    cmd_open   "$@" ;;
    repo)      cmd_repo      "$@" ;;
    pull)      cmd_pull      "$@" ;;
    commit)    cmd_commit    "$@" ;;
    push)      cmd_push      "$@" ;;
    hygiene)   cmd_hygiene   "$@" ;;
    autostart) cmd_autostart "$@" ;;
    add)       cmd_add       "$@" ;;
    config)    cmd_config    "$@" ;;
    reload) info "Reloading apps.json…"; api POST /api/apps/reload | jq -r '.message' ;;
    help|--help|-h) cmd_help ;;
    *) die "Unknown command '${CMD}'. Run 'fd help' for usage." ;;
esac
